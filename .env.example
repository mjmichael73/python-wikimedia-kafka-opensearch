# Copy to `.env` at the repo root and adjust. Docker Compose loads `.env` for
# interpolation; values below match the defaults baked into the apps.

# --- Producer: Wikimedia SSE ---
WIKIMEDIA_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange

# --- Kafka (comma-separated host:port; inside Compose use service name broker) ---
KAFKA_BOOTSTRAP_SERVERS=broker:9092
KAFKA_TOPIC=wikimedia.recentchange
KAFKA_CONSUMER_GROUP=wikimedia-consumer-group
# Dead-letter topic for failed OpenSearch indexing; set empty to disable (offset still committed).
KAFKA_DLQ_TOPIC=wikimedia.recentchange.dlq

# --- OpenSearch (HTTP from the consumer container) ---
OPENSEARCH_HOST=opensearch-node1
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=wikimedia-changes
# Secure OpenSearch (security plugin + HTTPS): see README "OpenSearch secure mode".
# OPENSEARCH_USE_SSL=true
# OPENSEARCH_USER=admin
# OPENSEARCH_PASSWORD=your-admin-password
# OPENSEARCH_VERIFY_CERTS=false
# OPENSEARCH_SSL_ASSERT_HOSTNAME=false
# OPENSEARCH_CA_CERTS=/path/inside/consumer/container/to/ca-bundle.pem

# --- Observability (both apps): JSON logs to stdout; HTTP on OBS_HTTP_PORT inside container ---
LOG_LEVEL=INFO
OBS_HTTP_PORT=8080
# Host port mappings (docker-compose): producer -> 8080, consumer -> 8081 by default
PRODUCER_OBS_HOST_PORT=8080
CONSUMER_OBS_HOST_PORT=8081

# --- Prometheus / Grafana (docker-compose) ---
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Connection retries (in-app, after containers start) ---
KAFKA_CLIENT_RETRY_MAX_ATTEMPTS=10
KAFKA_CLIENT_RETRY_DELAY_SECONDS=5
OPENSEARCH_RETRY_MAX_ATTEMPTS=20
OPENSEARCH_RETRY_DELAY_SECONDS=5
